NODE_ENV=development
PORT=4174

# Production: set this to a managed Postgres connection string.
# Example providers: Neon, Supabase, Railway, Render Postgres.
DATABASE_URL=

# Set DEMO_MODE=true only for local testing without Postgres.
DEMO_MODE=true

# Generate a long random value before deployment.
JWT_SECRET=replace-with-a-long-random-secret

# Comma-separated origins allowed to call the API.
CORS_ORIGIN=http://localhost:4173

# Optional integration keys. Store this in Vercel Environment Variables.
# Never commit a real key.
API_KEYS=ll_demo_fasttrack_20260721_local_only

# Local-only: seed the bundled 36-question bank and demo accounts.
SEED_DEMO_DATA=true

# Production should normally leave this false and run a controlled seed job once.
ALLOW_TEACHER_SIGNUP=false

# Keep this token on the backend only. Never expose it in app.js or the browser.
HF_TOKEN=
HF_MODEL=openai/gpt-oss-20b:cheapest
HF_FALLBACK_MODELS=HuggingFaceTB/SmolLM3-3B:cheapest
HF_PREFER_FREE=true
# Set true if you want to refuse any model that HF does not report as free.
HF_FREE_ONLY=false
AI_INSIGHTS_ENABLED=true
AI_INSIGHTS_CACHE_MINUTES=30
