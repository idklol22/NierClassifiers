{
  "version": 2,
  "functions": {
    "api/index.js": { "runtime": "@vercel/node" }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/docs(.*)", "dest": "/api/index.js" },
    { "src": "/openapi.json", "dest": "/api/index.js" },
    { "src": "/health", "dest": "/api/index.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
